{
  "name": "possap-api",
  "version": "0.0.1",
  "description": "Police Specialised Services Automation Project",
  "author": "elegee2 <58389328+EleGee2@users.noreply.github.com>",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:worker": "WORKLOADS=worker nest start --config worker.nest-cli.json",
    "start:dev": "nest start --watch | pino-pretty",
    "start:worker:dev": "WORKLOADS=worker nest start --watch --config worker.nest-cli.json | pino-pretty",
    "start:debug": "nest start --debug --watch | pino-pretty",
    "start:worker:debug": "WORKLOADS=worker nest start --debug --watch --config worker.nest-cli.json | pino-pretty",
    "start:prod": "node --enable-source-maps dist/main",
    "start:worker:prod": "WORKLOADS=worker node --enable-source-maps dist/worker",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "yarn lint --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "LOGGING_LEVEL=silent jest --config ./test/jest-e2e.json",
    "migration:new": "ts-node ./scripts/migrator.ts create --name",
    "migration:up": "ts-node ./scripts/migrator.ts up",
    "migration:down": "ts-node ./scripts/migrator.ts down",
    "seed:new": "ts-node ./scripts/seeder.ts create --name",
    "seed:up": "ts-node ./scripts/seeder.ts up",
    "seed:down": "ts-node ./scripts/seeder.ts down"
  },
  "engines": {
    "yarn": "1.x",
    "node": "20.x"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/sequelize": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ms": "^2.1.0",
    "@types/pg": "^8.20.0",
    "@types/sequelize": "^6.12.0",
    "argon2": "^0.44.0",
    "axios": "^1.14.0",
    "bullmq": "^5.71.1",
    "date-fns": "^4.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.1.1",
    "joi-errors": "^0.2.0",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "my-ua-parser": "^2.0.4",
    "nanoid": "^5.1.7",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sequelize": "^6.37.8",
    "sequelize-typescript": "^2.1.6",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "main": "index.js"
}
